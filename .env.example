# ── База данных ────────────────────────────────────────────────────────────
# Для скриптов и uvicorn на хосте (PostgreSQL в Docker, порт 5432 проброшен):
DATABASE_URL=postgresql://postgres:password@localhost:5432/perfume_db
# В контейнерах Docker compose подставит хост postgres автоматически

POSTGRES_DB=perfume_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password

# ── DeepSeek API ────────────────────────────────────────────────────────────
DEEPSEEK_API_KEY=sk-your-deepseek-key-here
DEEPSEEK_MODEL=deepseek-chat

# ── OpenAI API (опционально, приоритет выше DeepSeek) ──────────────────────
OPENAI_API_KEY=
EMBEDDING_MODEL=cointegrated/rubert-tiny2
LLM_MODEL=gpt-4-turbo-preview

# ── JWT / Security ──────────────────────────────────────────────────────────
JWT_SECRET=your-jwt-secret-key-change-this-in-production
JWT_EXPIRE_DAYS=7
SECRET_KEY=your-super-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ── Email ───────────────────────────────────────────────────────────────────
# console — код выводится в лог (для разработки)
# smtp    — реальная отправка
EMAIL_BACKEND=console

# Яндекс (порт 465, SSL):
SMTP_HOST=smtp.yandex.ru
SMTP_PORT=465
SMTP_USE_TLS=false
SMTP_USER=your-email@yandex.ru
SMTP_PASSWORD=your-app-password   # пароль приложения из настроек Яндекс ID
SMTP_FROM=your-email@yandex.ru

# Gmail (порт 587, STARTTLS):
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USE_TLS=true
# SMTP_USER=your@gmail.com
# SMTP_PASSWORD=your-app-password

# ── Приложение ──────────────────────────────────────────────────────────────
DEBUG=false
API_V1_PREFIX=/api/v1
PROJECT_NAME=Perfume Selection API
BACKEND_CORS_ORIGINS=["http://localhost:3000", "http://localhost:8000"]

# ── Embedding ───────────────────────────────────────────────────────────────
EMBEDDING_DIMENSION=312
EMBEDDING_BATCH_SIZE=100

# ── Поиск ───────────────────────────────────────────────────────────────────
DEFAULT_SEARCH_LIMIT=5
MAX_SEARCH_QUERY_LENGTH=1000
MIN_SEARCH_QUERY_LENGTH=3

# ── Rate limiting ───────────────────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=60
